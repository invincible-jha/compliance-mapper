{
  "name": "@aumos/compliance-mapper",
  "version": "0.1.0",
  "description": "Auto-generate SOC 2, GDPR, and EU AI Act compliance evidence from governance configs and audit logs",
  "license": "SEE LICENSE IN ../LICENSE",
  "author": "MuVeraAI Corporation",
  "homepage": "https://github.com/muveraai/aumos-oss/tree/main/compliance-mapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/muveraai/aumos-oss.git",
    "directory": "compliance-mapper/typescript"
  },
  "keywords": [
    "compliance",
    "soc2",
    "gdpr",
    "eu-ai-act",
    "governance",
    "audit",
    "evidence"
